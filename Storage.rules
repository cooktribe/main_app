rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@cooktribe.app';
    }
    
    // User profile images - public read, owner write
    match /users/{userId}/profile/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
      // Admin can access all user files
      allow read, write: if isAdmin();
    }
    
    // Event images - public read, authenticated write
    match /events/{eventId}/images/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
      // Admin has full access
      allow read, write: if isAdmin();
    }
    
    // Verification documents - private to user and admin
    match /verification/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Admin can access all verification documents (for approval process)
      allow read, write: if isAdmin();
    }
    
    // Admin-specific storage (for admin uploads, backups, etc.)
    match /admin/{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}